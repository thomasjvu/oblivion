# Copy to .env.infisical (gitignored). Source before secrets:* commands.
# Infisical: https://infisical.phantasy.bot/organizations/3f80ae72-bc03-474a-8b14-108b3bb2dbf4/projects/secret-management/baa5ece8-bf19-441b-96f9-5d3f6affd104/overview

# Machine identity (Universal Auth) — preferred for scripts/CI
INFISICAL_MACHINE_CLIENT_ID=
INFISICAL_MACHINE_CLIENT_SECRET=

# One-time bootstrap: base64 export from Infisical CLI/browser (not for daily use)
# INFISICAL_CREDENTIALS_BLOB=

# Optional direct bearer token instead of machine identity
# INFISICAL_ACCESS_TOKEN=

# Project binding (defaults from .infisical.json if unset)
INFISICAL_PROJECT_ID=baa5ece8-bf19-441b-96f9-5d3f6affd104
INFISICAL_ORGANIZATION_ID=3f80ae72-bc03-474a-8b14-108b3bb2dbf4
INFISICAL_DOMAIN=https://infisical.phantasy.bot

# Cloudflare Access service token for headless Infisical API (optional locally if cloudflared login is active)
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=