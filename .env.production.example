# Production operator env — populated by `npm run secrets:pull:prod` (never commit).
#
# Infisical prod stores API keys, CDP credentials, and deploy URLs.
# Runtime profile (live executor, Base mainnet x402, file store, no plaintext logs)
# is derived from OBLIVION_DEPLOYMENT_ENV=production in deploymentEnv.ts.
#
# Deploy: npm run deploy:production  (pulls prod secrets automatically)

# Infisical-managed keys — see scripts/lib/secrets-config.mjs PROD_SYNC_KEYS
BRAVE_SEARCH_API_KEY=
VENICE_API_KEY=
HIBP_API_KEY=
ONESHOT_API_KEY=
X402_PAY_TO=
X402_CDP_API_KEY_ID=
X402_CDP_API_KEY_SECRET=
OBLIVION_PUBLIC_API_URL=https://your-phala-host.dstack-pha-prod5.phala.network
OBLIVION_CORS_ORIGIN=https://oblivion.phantasy.bot
PHALA_ATTESTATION_URL=