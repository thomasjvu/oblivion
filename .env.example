# Copy to .env and fill in values. Never commit .env.

# --- Server ---
PORT=8080
TRUST_CENTER_PATH=config/trust-center.json
# Persistent JSON store (cases, payments, relayer events survive restart)
OBLIVION_STORE=file
OBLIVION_STORE_PATH=
# Public API origin for 1Shot destinationUrl webhooks (Phala hostname)
OBLIVION_PUBLIC_API_URL=
# Cloudflare Workers UI origin allowed for cross-origin API calls
OBLIVION_CORS_ORIGIN=

# --- Privacy / execution (production) ---
# record-only = store approved packets only; live = call connectors after approval + TEE pass
OBLIVION_EXECUTOR_MODE=record-only
OBLIVION_DISABLE_PLAINTEXT_LOGS=true

# --- Phala TDX attestation (required before sensitive managed-plaintext connectors) ---
# On Phala CVM, compose sets this from DSTACK_APP_ID + DSTACK_GATEWAY_DOMAIN (/tcbinfo)
PHALA_ATTESTATION_URL=
PHALA_VERIFIER_ENDPOINT=https://cloud-api.phala.com/api/v1/attestations/verify
ATTESTATION_MAX_AGE_SECONDS=600

# --- Brave Search (exposure discovery; privacy-preserving web search API) ---
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1/web/search
BRAVE_SEARCH_COUNT=20

# --- Venice AI agent (classify, draft, review, chat, match scoring) ---
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=

# --- Have I Been Pwned (live email check; password range is prefix-only, no key required) ---
HIBP_API_KEY=

# --- MetaMask Smart Account (optional live Sepolia upgrade) ---
WALLET_LIVE_MODE=true
WALLET_CHAIN_ID=11155111

# --- x402 HTTP payments (Coinbase open protocol) ---
# Testnet facilitator (no signup): https://x402.org/facilitator
# Mainnet/CDP: https://api.cdp.coinbase.com/platform/v2/x402 + CDP keys below
X402_ENABLED=true
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_PAY_TO=0xYourWalletAddressHere
X402_NETWORK=eip155:84532
X402_CDP_API_KEY_ID=
X402_CDP_API_KEY_SECRET=

# --- Outbound email (broker opt-out + platform abuse live connectors) ---
RESEND_API_KEY=
SMTP_FROM=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# --- 1Shot public relayer (EIP-7710 gas abstraction) ---
ONESHOT_BASE_URL=https://relayer.1shotapi.com/relayers
ONESHOT_API_KEY=
# Optional x-1shot-authorization header for signed delegation auth (usually leave empty for public relayer)
ONESHOT_AUTHORIZATION=