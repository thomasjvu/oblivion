# Copy to .env and fill in values. Never commit .env.

# --- Server ---
PORT=8080
# Expose /api/hackathon/* sponsor-track endpoints (off by default in production)
# HACKATHON_MODE=true
# Public documentation site (app redirects /help, /developers, etc.)
OBLIVION_DOCS_URL=https://oblivion-docs.phantasy.bot
# development = Sepolia testnets (Base Sepolia x402 + Ethereum Sepolia wallet)
# production = Base mainnet x402 + Base wallet (used when NODE_ENV=production if unset)
OBLIVION_DEPLOYMENT_ENV=development

# --- Partner API (B2B rail) ---
# Format: partnerId:apiKey,anotherPartner:anotherKey
OBLIVION_PARTNER_KEYS=demo:obl_live_change_me
OBLIVION_PARTNER_SANDBOX_KEYS=demo-sandbox:obl_sandbox_change_me
OBLIVION_PARTNER_DEFAULT_CREDITS=1000
OBLIVION_PARTNER_SANDBOX_CREDITS=500
# Partner-visible presets (default: people-search-cleanup,breach-exposure)
# OBLIVION_PARTNER_PRESETS=people-search-cleanup,breach-exposure
# OBLIVION_PARTNER_RATE_CASE=10
# OBLIVION_PARTNER_RATE_DISCOVER=5
# OBLIVION_PARTNER_RATE_EXECUTE=15
# OBLIVION_PARTNER_RATE_AI=2
# OBLIVION_PARTNER_ADMIN_TOKEN=change_me_for_ops_refill
# OBLIVION_WEBHOOK_MAX_RETRIES=5
# OBLIVION_WEBHOOK_RETRY_BASE_MS=60000
# OBLIVION_WEBHOOK_RETRY_ENABLED=true
TRUST_CENTER_PATH=config/trust-center.json
# Persistent JSON store (cases, payments, relayer events survive restart)
OBLIVION_STORE=file
OBLIVION_STORE_PATH=
# Public API origin for 1Shot destinationUrl webhooks (Phala hostname)
OBLIVION_PUBLIC_API_URL=
# Cloudflare Workers UI origin allowed for cross-origin API calls
OBLIVION_CORS_ORIGIN=

# --- Privacy / execution (production) ---
# record-only = store approved packets only; live = call connectors after approval + TEE pass
OBLIVION_EXECUTOR_MODE=record-only
OBLIVION_DISABLE_PLAINTEXT_LOGS=true
# Dev/test only — skip x402 paid-session gate for Venice chat/analysis (never enable in production)
# OBLIVION_AI_BYPASS_PAYMENT=true
# Dev/test/E2E — skip wallet credit debits for discovery and activation (never enable in production)
# OBLIVION_CREDITS_BYPASS=true

# --- Phala TDX attestation (required before sensitive managed-plaintext connectors) ---
# On Phala CVM, compose sets this from DSTACK_APP_ID + DSTACK_GATEWAY_DOMAIN (/tcbinfo)
PHALA_ATTESTATION_URL=
PHALA_VERIFIER_ENDPOINT=https://cloud-api.phala.com/api/v1/attestations/verify
ATTESTATION_MAX_AGE_SECONDS=600

# --- Exposure discovery web search ---
# Primary: direct Brave Search API (hosted + self-hosted).
# Fallback: Venice augment/search (Brave ZDR via VENICE_API_KEY) when Brave quota/errors occur.
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1/web/search
BRAVE_SEARCH_COUNT=20
BRAVE_SEARCH_COUNTRY=US
BRAVE_SEARCH_LANG=en
# Onboarding preview: brokers swept + max site-scoped queries (variants per broker)
# OBLIVION_PREVIEW_BROKER_SWEEP=20
# OBLIVION_PREVIEW_SWEEP_QUERIES=30
# OBLIVION_PREVIEW_SEARCH_CONCURRENCY=4
# OBLIVION_PREVIEW_DAILY_LIMIT=0
# OBLIVION_PREVIEW_RESULT_LIMIT=12

# --- Venice AI agent (classify, draft, review, chat, match scoring, web search) ---
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=

# --- Have I Been Pwned (live email check; password range is prefix-only, no key required) ---
HIBP_API_KEY=

# --- MetaMask Smart Account (optional live upgrade) ---
WALLET_LIVE_MODE=true
# Optional override; defaults from OBLIVION_DEPLOYMENT_ENV (11155111 dev, 8453 prod)
# WALLET_CHAIN_ID=11155111

# --- x402 HTTP payments (Coinbase open protocol) ---
# Development defaults: Base Sepolia + https://x402.org/facilitator (no signup)
# Production defaults: Base mainnet + CDP facilitator (requires keys below)
X402_ENABLED=true
# X402_FACILITATOR_URL=https://x402.org/facilitator
# X402_NETWORK=eip155:84532
# Must be a real wallet — 0x000… is treated as unset and disables x402
X402_PAY_TO=0xYourWalletAddressHere
X402_CDP_API_KEY_ID=
X402_CDP_API_KEY_SECRET=

# --- Outbound email (broker opt-out + platform abuse live connectors) ---
RESEND_API_KEY=
SMTP_FROM=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# --- 1Shot public relayer (EIP-7710 gas abstraction) ---
ONESHOT_BASE_URL=https://relayer.1shotapi.com/relayers
ONESHOT_API_KEY=
# Optional x-1shot-authorization header for signed delegation auth (usually leave empty for public relayer)
ONESHOT_AUTHORIZATION=

# Map broker web-form fields for TEE handoff (still requires user approval; no auto-submit)
BROKER_WEBFORM_AUTOMATION=false
