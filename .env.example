# Copy to .env for local development. Never commit .env.
#
# Infisical stores API keys + deploy URLs only (npm run secrets:pull:dev).
# Profile defaults (x402 network, executor mode, chain IDs, etc.) live in
# src/domain/deploymentEnv.ts — set OBLIVION_DEPLOYMENT_ENV=development locally.

# --- Infisical-managed (synced via secrets:pull:dev / secrets:push:dev) ---
BRAVE_SEARCH_API_KEY=
VENICE_API_KEY=
ONESHOT_API_KEY=
X402_PAY_TO=0xYourWalletAddressHere
OBLIVION_PUBLIC_API_URL=
OBLIVION_CORS_ORIGIN=

# --- Optional local overrides (not synced to Infisical) ---
# OBLIVION_DEPLOYMENT_ENV=development
# PORT=8080
# HACKATHON_MODE=true
# OBLIVION_DOCS_URL=https://oblivion-docs.phantasy.bot
# OBLIVION_STORE_PATH=
# PHALA_ATTESTATION_URL=
# VENICE_MODEL=
# HIBP_API_KEY=
# X402_CDP_API_KEY_ID=
# X402_CDP_API_KEY_SECRET=
# RESEND_API_KEY=
# SMTP_FROM=
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
# ONESHOT_AUTHORIZATION=
# OBLIVION_PARTNER_KEYS=demo:obl_live_change_me
# OBLIVION_PARTNER_SANDBOX_KEYS=demo-sandbox:obl_sandbox_change_me
# OBLIVION_PARTNER_DEFAULT_CREDITS=1000
# OBLIVION_PARTNER_SANDBOX_CREDITS=500
# OBLIVION_PARTNER_ADMIN_TOKEN=
# OBLIVION_AI_BYPASS_PAYMENT=true
# OBLIVION_CREDITS_BYPASS=true
# BROKER_WEBFORM_AUTOMATION=false