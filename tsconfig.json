{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "test/**/*.d.ts", "packages/**/*.d.ts", "docs/**/*.d.ts", "test/e2e/global.d.ts"]
}
