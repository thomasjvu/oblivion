{
  "name": "oblivion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal information removal without giving away your personal information — consumer app and partner API.",
  "scripts": {
    "build:icons": "node scripts/subset-icon-collections.mjs",
    "build:client": "npm run build:icons && esbuild public/src/main.js --bundle --format=esm --splitting --minify --outdir=public --entry-names=app --chunk-names=chunk-[hash] --packages=bundle --loader:.ts=ts --loader:.json=json",
    "build:server": "tsc -p tsconfig.build.json",
    "build:vault-sdk": "npm run build --prefix packages/vault-sdk",
    "publish:partner-packages": "npm run build:vault-sdk && npm publish --prefix packages/vault-sdk && npm publish --prefix packages/partner-sdk && npm publish --prefix packages/partner-ui",
    "build:fonts": "test -f public/fonts/GeistPixel-Square.woff2",
    "generate:brand-icons": "node scripts/generate-brand-icons.mjs",
    "dev": "npm run build:client && npm run build:fonts && node --env-file-if-exists=.env --import tsx src/server.ts",
    "test": "tsx --test 'test/**/*.test.ts'",
    "e2e": "playwright test",
    "e2e:people-search": "playwright test test/e2e/people-search-findings.spec.ts --project=desktop",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test scripts",
    "openapi:verify": "node scripts/verify-openapi.mjs",
    "verify": "npm run version:sync && npm run build:client && npm run build:server && npm run build:vault-sdk && npm run build:fonts && npm test && npm run typecheck && npm run lint && npm run openapi:verify && npm run design:lint",
    "docs:dev": "npm run dev --prefix docs",
    "docs:build": "npm run build --prefix docs",
    "docs:verify": "npm run release:check --prefix docs",
    "version:sync": "tsx scripts/sync-app-version.ts",
    "design:lint": "designmd lint DESIGN.md",
    "docker:build": "docker build -t ghcr.io/thomasjvu/oblivion:local .",
    "docker:build:remote": "bash scripts/build-on-spectre.sh",
    "docker:run": "docker run --rm -p 8080:8080 -e PHALA_ATTESTATION_URL -e OBLIVION_DISABLE_PLAINTEXT_LOGS=true ghcr.io/thomasjvu/oblivion:local",
    "docker:pin": "bash scripts/pin-production-image.sh",
    "phala:deploy": "bash scripts/deploy-phala.sh",
    "phala:sync-trust": "bash scripts/sync-phala-trust-center.sh",
    "secrets:pull:dev": "node scripts/infisical-sync.mjs pull --env dev",
    "secrets:pull:prod": "node scripts/infisical-sync.mjs pull --env prod",
    "secrets:push:dev": "node scripts/infisical-sync.mjs push --env dev",
    "secrets:push:prod": "node scripts/infisical-sync.mjs push --env prod",
    "secrets:backup:dev": "node scripts/infisical-sync.mjs backup --env dev",
    "secrets:backup:prod": "node scripts/infisical-sync.mjs backup --env prod",
    "secrets:prune:dev": "node scripts/infisical-sync.mjs prune --env dev",
    "secrets:prune:prod": "node scripts/infisical-sync.mjs prune --env prod",
    "secrets:doctor": "node scripts/secrets-doctor.mjs",
    "secrets:bootstrap": "node scripts/infisical-bootstrap.mjs",
    "deploy:production": "bash scripts/deploy-production.sh",
    "deploy:cloudflare-ui": "bash scripts/deploy-cloudflare-ui.sh",
    "workers:dev": "wrangler dev --config workers/wrangler.toml",
    "workers:deploy": "wrangler deploy --config workers/wrangler.toml"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@iconify-json/pixel": "1.2.2",
    "@iconify-json/pixelarticons": "1.2.6",
    "@noble/hashes": "1.8.0",
    "@phala/dstack-sdk": "0.5.8",
    "@phantasy/vn-tts": "0.1.0",
    "@x402/core": "2.14.0",
    "@x402/evm": "2.17.0",
    "iconify-icon": "3.0.2",
    "tsx": "4.22.4"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@google/design.md": "0.2.0",
    "@playwright/test": "1.60.0",
    "@types/node": "25.9.1",
    "esbuild": "0.28.1",
    "eslint": "9.39.1",
    "globals": "16.5.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "ws": "8.21.0"
  }
}
