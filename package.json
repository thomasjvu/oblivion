{
  "name": "oblivion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Trust-minimized supervised online identity cleanup agent.",
  "scripts": {
    "build:client": "esbuild public/src/main.js --bundle --format=esm --outfile=public/app.js --packages=bundle --loader:.ts=ts",
    "build:fonts": "cp node_modules/geist/dist/fonts/geist-pixel/GeistPixel-Square.woff2 public/fonts/GeistPixel-Square.woff2",
    "build:legal": "tsx scripts/build-legal-pages.ts",
    "dev": "npm run build:client && npm run build:fonts && npm run build:legal && tsx src/server.ts",
    "test": "tsx --test test/*.test.ts",
    "e2e": "playwright test",
    "e2e:people-search": "playwright test test/e2e/people-search-findings.spec.ts --project=desktop",
    "typecheck": "tsc --noEmit",
    "verify": "npm run build:client && npm run build:fonts && npm run build:legal && npm test && npm run typecheck && npm run design:lint",
    "smoke:people-search": "tsx test/smoke-people-search.mjs",
    "design:lint": "npx @google/design.md lint DESIGN.md",
    "docker:build": "docker build -t ghcr.io/thomasjvu/oblivion:local .",
    "docker:build:remote": "bash scripts/build-on-spectre.sh",
    "docker:run": "docker run --rm -p 8080:8080 -e PHALA_ATTESTATION_URL -e OBLIVION_DISABLE_PLAINTEXT_LOGS=true ghcr.io/thomasjvu/oblivion:local",
    "docker:pin": "bash scripts/pin-production-image.sh",
    "phala:deploy": "bash scripts/deploy-phala.sh"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@iconify-json/pixel": "^1.2.2",
    "@iconify-json/pixelarticons": "^1.2.6",
    "@x402/core": "^2.14.0",
    "@x402/evm": "^2.14.0",
    "geist": "^1.7.2",
    "iconify-icon": "^3.0.2",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
